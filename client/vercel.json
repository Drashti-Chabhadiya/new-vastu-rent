{
  "ignoreCommand": "git diff HEAD^ HEAD --quiet -- .",
  "headers": [
    {
      "source": "/app-release.apk",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/vnd.android.package-archive"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"VastuRent.apk\""
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
